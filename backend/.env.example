# Backend environment variables (Railway: backend service)
PORT=8080
FRONTEND_ORIGIN=https://your-frontend.up.railway.app

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...anon...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...

# Auth allowlist (comma-separated)
ALLOWED_EMAILS=ty@viewmovement.com,content@viewmovement.com

# Google Sheets service account (create in GCP, grant Viewer on both sheets)
GOOGLE_SERVICE_ACCOUNT_EMAIL=crm-sync@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Sheet IDs (already defaulted in code to your current sheets)
ONBOARDING_SHEET_ID=17fd_Jhi7wXN0lgo0Z3CzWs4XDDz3zbAltPZALV1KKO4
ONBOARDING_SHEET_RANGE=Onboarding Form!A1:BQ
CANCELLATION_SHEET_ID=16c_iZfITqH9QKZLIuurblzDcmksXcCqcdXW_ISOrRZ8
CANCELLATION_SHEET_RANGE=View Movement Cancellation Form!A1:AY

# Set to "false" to disable in-process pollers (e.g. if you run them as a cron)
ENABLE_POLLERS=true
